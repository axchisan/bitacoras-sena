# =============================================================================
# BITÁCORAS SENA — Variables de entorno
# Copia este archivo como .env y completa los valores
# =============================================================================

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Contraseña de la base de datos. Cámbiala por algo seguro en producción.
# El resto de la URL (host, usuario, db) se construye automáticamente en docker-compose.
POSTGRES_PASSWORD=bitacoras_pass_2026

# ─── Azure DevOps ─────────────────────────────────────────────────────────────
# Organización en Azure DevOps (lo que va en dev.azure.com/[esto])
AZURE_DEVOPS_ORG=linktic

# Nombre exacto del proyecto en Azure DevOps
AZURE_DEVOPS_PROJECT=397 - COLFONDOS CORE

# Personal Access Token (PAT):
# 1. Ve a https://dev.azure.com/linktic
# 2. Clic en tu avatar (arriba derecha) → "Personal access tokens"
# 3. "New Token" → Name: "bitacoras-app" → Expiration: 1 año
# 4. Scopes: Work Items → Read   (solo necesitas lectura)
# 5. Copia el token generado aquí (solo se muestra una vez)
AZURE_DEVOPS_PAT=aqui_va_tu_pat

# ─── Anthropic / Claude ───────────────────────────────────────────────────────
# Tu API Key de Anthropic.
# La misma que usas con Claude Code.
# La encuentras en: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-aqui_va_tu_key

# ─── OneDrive / Microsoft Graph ───────────────────────────────────────────────
# Para subir los Excel automáticamente a OneDrive.
# Si no lo configuras ahora, la app funciona igual — solo desactiva el botón OneDrive.
#
# Cómo obtener estas credenciales:
# 1. Ve a https://portal.azure.com → "App registrations" → "New registration"
# 2. Nombre: "bitacoras-sena", tipo: "Accounts in this organizational directory only"
# 3. En la app creada: copia el "Application (client) ID" → ONEDRIVE_CLIENT_ID
# 4. En la app: copia el "Directory (tenant) ID" → ONEDRIVE_TENANT_ID
# 5. "Certificates & secrets" → "New client secret" → copia el valor → ONEDRIVE_CLIENT_SECRET
# 6. "API permissions" → "Add permission" → Microsoft Graph → Delegated → Files.ReadWrite
#
# Por ahora puedes dejar estos en blanco — la app detecta si están configurados:
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=
ONEDRIVE_TENANT_ID=
# Carpeta en tu OneDrive donde se guardan los Excel (se crea automáticamente)
ONEDRIVE_FOLDER_PATH=/Bitacoras SENA

# ─── App ─────────────────────────────────────────────────────────────────────
# Clave secreta para firmado interno. Genera una con: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=genera_una_clave_aleatoria_aqui

# Entorno: development (muestra logs SQL) o production
ENVIRONMENT=production

# Orígenes permitidos para CORS (tu dominio en producción, localhost en local)
# Separa múltiples orígenes con coma, sin espacios
CORS_ORIGINS=http://localhost:8080,https://tu-dominio.com

# ─── Puerto del nginx ─────────────────────────────────────────────────────────
# En LOCAL usa 8080 para no interferir con otros servicios
# En PRODUCCIÓN (Coolify) usa el que Coolify asigne — normalmente se deja vacío
#   porque Coolify maneja el routing con Traefik
NGINX_PORT=8080

# ─── Bitácoras ────────────────────────────────────────────────────────────────
# No cambies estos valores — definen tu etapa productiva
BITACORAS_START_DATE=2026-01-26
BITACORAS_TOTAL=12
BITACORAS_PERIOD_DAYS=15
