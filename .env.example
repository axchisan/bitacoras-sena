# =============================================================
# BITÁCORAS SENA — Variables de entorno
# Local: copia este archivo como .env y completa los valores
# Producción (Coolify): agrega cada variable en la UI de Coolify
# =============================================================

# Base de datos
POSTGRES_PASSWORD=

# Azure DevOps
AZURE_DEVOPS_ORG=linktic
AZURE_DEVOPS_PROJECT=397 - COLFONDOS CORE
AZURE_DEVOPS_PAT=

# Anthropic Claude API
ANTHROPIC_API_KEY=

# OneDrive (opcional — dejar vacío para desactivar)
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=
ONEDRIVE_TENANT_ID=
ONEDRIVE_FOLDER_PATH=/Bitacoras SENA

# App
SECRET_KEY=
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:8080

# Puerto nginx (local: 8080, en Coolify este valor lo ignora y usa su propio proxy)
NGINX_PORT=8080

# Configuración bitácoras (no modificar)
BITACORAS_START_DATE=2026-01-26
BITACORAS_TOTAL=12
BITACORAS_PERIOD_DAYS=15
